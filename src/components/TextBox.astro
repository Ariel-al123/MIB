---
const { placeholder } = Astro.props;
const { icon } = Astro.props;
---


<div class="input-container">
  <img src={icon} alt="" id="icon">
  <input type="text" placeholder={placeholder} />
</div>

<style>

    .input-container {
        position: relative;
        width: 60%;
        margin: 2% auto;
    }
    input {
        width: 100%;
        padding: 4% 5% 4% 15%;
        margin: 8px 0;
        box-sizing: border-box;
        background-color: #e8effb;
        border-radius: 15px;
        border: none;
        outline: none;
    }

    #icon {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        width: 22px;
        height: 22px;
        color: #ccc;
    }

    #icon:hover {
        color: #ffffff00;
    }

    input:hover {
        background-color: #c7d6f1;
    }

    input:hover::placeholder {
        color: #ffffff00;
    }

</style>

