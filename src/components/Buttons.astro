---
const { text } = Astro.props;

---


<input type="submit" value={text} id="Boton-Login">

<style>
    #Boton-Login{
        background-color: #000000;
        color: #FFFFFF;
        border: none;
        padding: 10px 20px;
        cursor: pointer;
        border-radius: 15px;
        background: #787878;
        background: linear-gradient(179deg, rgba(120, 120, 120, 1) 0%, rgba(0, 0, 0, 1) 100%);
    }

</style>